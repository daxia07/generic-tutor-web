{
  "name": "generic-tutor-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3099",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx src/lib/db/seed.ts",
    "refresh:fetch": "npx tsx scripts/fetch-progress.ts",
    "refresh:llm": "npx tsx scripts/llm-refresh-content.ts",
    "refresh": "npx tsx scripts/fetch-progress.ts > /tmp/progress.json 2>/dev/null && npx tsx scripts/llm-refresh-content.ts /tmp/progress.json",
    "refresh:dry": "npx tsx scripts/fetch-progress.ts > /tmp/progress.json 2>/dev/null && npx tsx scripts/llm-refresh-content.ts /tmp/progress.json --dry-run",
    "migrate:schema": "npx tsx scripts/migrate-schema.ts",
    "overnight": "npx tsx scripts/overnight-pipeline.ts",
    "overnight:dry": "npx tsx scripts/overnight-pipeline.ts --dry-run",
    "overnight:install-cron": "bash scripts/install-overnight-cron.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@mingli/auth": "github:daxia07/mingli-auth-shared",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
